{
  "name": "seal-home",
  "version": "0.3.3",
  "type": "module",
  "module": "src/server.ts",
  "bin": {
    "seal-home": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "probe": "bun run src/probe.ts",
    "cli": "bun run src/cli.ts",
    "check": "tsc --noEmit",
    "build:binary": "bun build --compile --outfile dist/bin/seal-home src/cli.ts",
    "openapi:bundle": "bun run scripts/bundle-openapi.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ky": "^2.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "bun-types": "^1.3.14",
    "typescript": "^5.9.3",
    "yaml": "^2.9.0"
  }
}
